# App
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:mysql://localhost:3306/prueba_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Lima&characterEncoding=UTF-8
DB_USER=root
DB_PASS=

# JPA
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# Security
APP_JWT_SECRET=replace-with-strong-random-secret-min-32-bytes
APP_JWT_EXPIRATION_MS=86400000
APP_SESSION_INACTIVITY_MINUTES=30

# Business
APP_OPERACION_MAX_PEDIDOS_DIA=200
APP_NOTIFICACION_CANAL_PREFERIDO=AUTO

# Auth anti-abuse
APP_AUTH_LOGIN_MAX_ATTEMPTS=5
APP_AUTH_LOGIN_WINDOW_SECONDS=300
APP_AUTH_LOGIN_BLOCK_SECONDS=900
APP_AUTH_RESET_MAX_ATTEMPTS=5
APP_AUTH_RESET_WINDOW_SECONDS=900
APP_AUTH_RESET_BLOCK_SECONDS=1800

# CORS
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:8081

# Payment gateway
APP_PAGO_GATEWAY=mock
APP_PAGO_CULQI_BASE_URL=https://api.culqi.com/v2
APP_PAGO_CULQI_SECRET_KEY=

# Notification email provider
APP_NOTIFICACION_EMAIL_PROVIDER=mock
APP_NOTIFICACION_EMAIL_FROM=no-reply@casachantilly.pe
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
